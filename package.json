{
  "name": "quicksend-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx prisma/seed.ts && tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "deploy": "npx prisma db push && tsx prisma/seed.ts && node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:upsert-treasury": "tsx prisma/upsert-treasury.ts",
    "sync": "powershell -NoProfile -File ../sync-to-rail.ps1",
    "sync:push": "powershell -NoProfile -File ../sync-to-rail.ps1 -Push"
  },
  "dependencies": {
    "@crossmint/common-sdk-base": "^0.10.2",
    "@crossmint/wallets-sdk": "^1.6.0",
    "@getbrevo/brevo": "^5.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.21.0",
    "resend": "^6.14.0",
    "twilio": "^6.0.2",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.13",
    "prisma": "^7.8.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0"
  }
}
