# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Database
DATABASE_URL=postgresql://user:password@host:5432/quicksend

# JWT
JWT_SECRET=change-this-to-a-secure-random-string

# Redis
REDIS_URL=redis://localhost:6379

# Resend (Email) - REQUIRED for email OTP and notifications
RESEND_API_KEY=
EMAIL_FROM=Quick Send <noreply@quicksend.com.mx>

# Twilio (SMS) - REQUIRED for SMS OTP and notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Crossmint
CROSSMINT_API_KEY=
CROSSMINT_BASE_URL=
TREASURY_SIGNER_SECRET=
TREASURY_RECOVERY_SECRET=
WALLET_SIGNER_SECRET=
WALLET_RECOVERY_SECRET=

# Wallet
USER_WALLET_CHAIN=base

# Networks
SUPPORTED_NETWORKS=BASE,ETHEREUM,SOLANA,POLYGON
NETWORK_CHAIN=base,ethereum,solana,polygon

# Treasury
TREASURY_CHAIN=base
HOT_TARGET=50000
HOT_THRESHOLD_MIN=20000
HOT_REFILL_AMOUNT=100000
WARM_TARGET=500000
WARM_THRESHOLD_MIN=250000
WARM_REFILL_AMOUNT=1000000
REFILL_INTERVAL=60000
