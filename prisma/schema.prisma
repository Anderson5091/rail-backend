generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id
  email           String           @unique
  phone           String?
  password        String
  fullName        String?
  country         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  phoneVerified   Boolean          @default(false)
  kycTier         Int              @default(0)
  kycStatus       String           @default("none")
  amlChecks       AmlCheck[]
  beneficiaries   Beneficiary[]
  complianceCases ComplianceCase[]
  depositWallets  DepositWallet[]
  kycDocuments    KycDocument[]
  kycEvents       KycEvent[]
  kycProfile      KycProfile?
  notifications   Notification[]
  otpCodes        OtpCode[]
  riskScore       RiskScore?
  sanctionsHits   SanctionsHit[]
  transfers       Transfer[]
  wallets         Wallet?
}

model OtpCode {
  id        String   @id
  userId    String?
  code      String
  type      String   @default("PHONE_VERIFICATION")
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  data      Json?
  email     String?
  token     String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Wallet {
  id                String              @id
  userId            String              @unique
  currency          String              @default("USDT")
  status            String              @default("ACTIVE")
  crossmintWalletId String?             @unique
  crossmintLocator  String?
  crossmintAddress  String?
  crossmintChain    String              @default("base")
  ledgerEntries     LedgerEntry[]
  user              User                @relation(fields: [userId], references: [id])
  addresses         WalletAddress[]
  transactions      WalletTransaction[]
}

model WalletAddress {
  id       String @id
  walletId String
  network  String
  address  String @unique
  wallet   Wallet @relation(fields: [walletId], references: [id])
}

model WalletTransaction {
  id                String   @id
  walletId          String
  type              String
  amount            Decimal  @db.Decimal(24, 8)
  network           String?
  txHash            String?
  status            String   @default("PENDING")
  transactionNumber String?
  payoutOrderId     String?
  createdAt         DateTime @default(now())
  wallet            Wallet   @relation(fields: [walletId], references: [id])
}

model LedgerEntry {
  id        String   @id
  walletId  String
  type      String
  amount    Decimal  @db.Decimal(24, 8)
  reference String?
  comment   String?
  uniqueKey String?  @unique
  createdAt DateTime @default(now())
  wallet    Wallet   @relation(fields: [walletId], references: [id])
}

model Beneficiary {
  id                 String    @id
  userId             String?
  fullName           String
  country            String
  payoutMethod       String
  bankName           String?
  accountNumber      String?
  accountCurrency    String?
  mobileWalletNumber String?
  mobileProvider     String?
  cashPickupLocation String?
  createdAt          DateTime  @default(now())
  user               User?     @relation(fields: [userId], references: [id])
}

model FxRate {
  id           String   @id
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(24, 8)
  source       String   @default("allratestoday")
  updatedAt    DateTime @updatedAt

  @@unique([fromCurrency, toCurrency])
}

model FeeRule {
  id           String  @id
  country      String
  payoutMethod String
  fixedFee     Decimal @db.Decimal(24, 8)
  percentFee   Decimal @db.Decimal(5, 2)
}

model Transfer {
  id                  String       @id
  userId              String?
  beneficiaryId       String?
  amount              Decimal      @db.Decimal(24, 8)
  payoutMethod        String?
  currency            String       @default("USD")
  status              String       @default("DRAFT")
  fxRate              Decimal?     @db.Decimal(24, 8)
  fee                 Decimal?     @db.Decimal(24, 8)
  destinationAmount   Decimal?     @db.Decimal(24, 8)
  referenceId         String?      @unique
  payoutOrderId       String?
  processingAgentId   String?
  proofImage          String?      @db.Text
  proofMimeType       String?
  completedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  payoutOrder         PayoutOrder?
  user                User?        @relation(fields: [userId], references: [id])
}

model PayoutOrder {
  id                String        @id
  transferId        String        @unique
  partner           String?
  payoutMethod      String?
  currency          String        @default("USD")
  status            String        @default("PENDING")
  externalReference String?
  attemptCount      Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  partnerLogs       PartnerLog[]
  payoutEvents      PayoutEvent[]
  transfer          Transfer      @relation(fields: [transferId], references: [id])
}

model PayoutEvent {
  id            String      @id
  payoutOrderId String
  eventType     String
  payload       Json?
  createdAt     DateTime    @default(now())
  payoutOrder   PayoutOrder @relation(fields: [payoutOrderId], references: [id])
}

model PartnerLog {
  id            String      @id
  payoutOrderId String
  partner       String
  request       Json?
  response      Json?
  statusCode    Int?
  createdAt     DateTime    @default(now())
  payoutOrder   PayoutOrder @relation(fields: [payoutOrderId], references: [id])
}

model TreasuryWallet {
  id                String             @id
  walletType        String
  network           String
  chain             String
  address           String             @unique
  crossmintWalletId String?
  walletLocator     String?
  balance           Decimal            @default(0) @db.Decimal(24, 8)
  thresholdMin      Decimal?           @db.Decimal(24, 8)
  thresholdMax      Decimal?           @db.Decimal(24, 8)
  status            String             @default("ACTIVE")
  lastSync          DateTime           @default(now())
  createdAt         DateTime           @default(now())
  movementsFrom     TreasuryMovement[]      @relation("FromWallet")
  movementsTo       TreasuryMovement[]      @relation("ToWallet")
  offrampOrders     TreasuryOfframpOrder[]
  onrampTransfers   TreasuryOnrampTransfer[]
}

model TreasuryMovement {
  id           String          @id
  fromWalletId String?
  toWalletId   String?
  fromWallet   String
  toWallet     String
  amount       Decimal         @db.Decimal(24, 8)
  network      String
  reason       String?
  status       String          @default("PENDING")
  txHash       String?
  createdAt    DateTime        @default(now())
  from         TreasuryWallet? @relation("FromWallet", fields: [fromWalletId], references: [id])
  to           TreasuryWallet? @relation("ToWallet", fields: [toWalletId], references: [id])
}

model LiquiditySnapshot {
  id           String   @id
  network      String
  chain        String
  hotBalance   Decimal  @db.Decimal(24, 8)
  warmBalance  Decimal  @db.Decimal(24, 8)
  coldBalance  Decimal  @db.Decimal(24, 8)
  totalBalance Decimal  @db.Decimal(24, 8)
  createdAt    DateTime @default(now())
}

model DepositRequest {
  id              String         @id
  userId          String
  chain           String
  token           String         @default("USDT")
  amount          Decimal?       @db.Decimal(24, 8)
  fee             Decimal?       @db.Decimal(24, 8)
  netAmount       Decimal?       @db.Decimal(24, 8)
  status          String         @default("PENDING")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  confirmations   Int            @default(0)
  depositWalletId String?
  txHash          String?
  depositWallet   DepositWallet? @relation(fields: [depositWalletId], references: [id])
}

model DepositWallet {
  id                String           @id
  crossmintWalletId String
  walletLocator     String
  address           String
  chain             String
  status            String           @default("ACTIVE")
  expiresAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  alias             String
  userId            String
  depositRequests   DepositRequest[]
  user              User             @relation(fields: [userId], references: [id])

  @@unique([userId, alias])
}

model Withdrawal {
  id                 String   @id
  userId             String
  walletId           String?
  amount             Decimal  @db.Decimal(24, 8)
  fee                Decimal  @default(0) @db.Decimal(24, 8)
  netAmount          Decimal  @db.Decimal(24, 8)
  chain              String
  destinationAddress String
  txHash             String?
  explorerLink       String?
  status             String   @default("PENDING")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TreasuryBankAccount {
  id              String   @id
  bankName        String?
  accountSuffix   String?
  routingNumber   String?
  currency        String   @default("USD")
  paymentMethodId String   @unique
  isDefault       Boolean  @default(false)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TreasuryOfframpOrder {
  id               String          @id
  paymentMethodId  String
  chain            String
  token            String          @default("USDC")
  amount           Decimal         @db.Decimal(24, 8)
  fee              Decimal?        @db.Decimal(24, 8)
  netAmount        Decimal         @db.Decimal(24, 8)
  fiatAmount       Decimal         @db.Decimal(24, 8)
  fiatCurrency     String          @default("USD")
  status           String          @default("PENDING")
  crossmintOrderId String?
  treasuryWalletId String?
  fromWalletType   String?
  txHash           String?
  explorerLink     String?
  failureReason    String?
  createdBy        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  treasuryWallet   TreasuryWallet? @relation(fields: [treasuryWalletId], references: [id])
}

model TreasuryOnrampTransfer {
  id               String          @id
  fiatAmount       Decimal         @db.Decimal(24, 8)
  fiatCurrency     String          @default("USD")
  token            String          @default("USDC")
  chain            String
  amount           Decimal?        @db.Decimal(24, 8)
  status           String          @default("PENDING")
  crossmintOrderId String?
  treasuryWalletId String?
  txHash           String?
  memoCode         String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  treasuryWallet   TreasuryWallet? @relation(fields: [treasuryWalletId], references: [id])
}

model KycProfile {
  id                   String   @id
  userId               String   @unique
  tier                 Int      @default(1)
  status               String   @default("PENDING")
  fullName             String?
  country              String?
  dateOfBirth          String?
  nationality          String?
  address              String?
  selfieUrl            String?
  diditVerificationId  String?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id])
}

model KycDocument {
  id           String   @id
  userId       String
  documentType String
  fileUrl      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model KycEvent {
  id         String   @id
  userId     String
  eventType  String
  status     String
  provider   String   @default("didit")
  rawPayload Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model AmlCheck {
  id            String   @id
  userId        String?
  transactionId String?
  riskLevel     String?
  flags         Json?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}

model SanctionsHit {
  id         String   @id
  userId     String?
  matchName  String?
  listSource String?
  status     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model ComplianceCase {
  id            String   @id
  userId        String?
  transactionId String?
  status        String?
  reason        String?
  assignedTo    String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}

model RiskScore {
  id        String   @id
  userId    String   @unique
  score     Int?
  level     String?
  factors   Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model IdempotencyKey {
  key         String   @id
  userId      String?
  status      String?
  response    Json?
  requestHash String?
  createdAt   DateTime @default(now())
}

model Event {
  id          String   @id
  aggregateId String
  type        String
  payload     Json?
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  @@unique([aggregateId, version])
}

model Notification {
  id         String                 @id
  userId     String?
  type       String?
  channel    String?
  title      String?
  message    String?
  status     String                 @default("PENDING")
  createdAt  DateTime               @default(now())
  user       User?                  @relation(fields: [userId], references: [id])
  deliveries NotificationDelivery[]
}

model NotificationDelivery {
  id             String        @id
  notificationId String?
  provider       String?
  status         String?
  response       Json?
  attemptCount   Int           @default(0)
  createdAt      DateTime      @default(now())
  notification   Notification? @relation(fields: [notificationId], references: [id])
}

model EventLog {
  id        String   @id
  eventType String
  entity    String?
  entityId  String?
  payload   Json?
  createdAt DateTime @default(now())
}

model Partner {
  id           String               @id
  name         String
  type         String
  country      String?
  status       String               @default("ACTIVE")
  baseUrl      String?
  apiKey       String?
  priority     Int                  @default(1)
  createdAt    DateTime             @default(now())
  slaMetrics   PartnerSlaMetric?
  transactions PartnerTransaction[]
  webhooks     PartnerWebhook[]
}

model PartnerTransaction {
  id                String   @id
  transferId        String?
  partnerId         String?
  externalReference String?
  status            String?
  requestPayload    Json?
  responsePayload   Json?
  createdAt         DateTime @default(now())
  partner           Partner? @relation(fields: [partnerId], references: [id])
}

model PartnerWebhook {
  id        String   @id
  partnerId String?
  eventType String?
  payload   Json?
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  partner   Partner? @relation(fields: [partnerId], references: [id])
}

model PartnerSlaMetric {
  id                String   @id
  partnerId         String   @unique
  successRate       Float?
  avgResponseTimeMs Int?
  failureCount      Int      @default(0)
  updatedAt         DateTime @updatedAt
  partner           Partner  @relation(fields: [partnerId], references: [id])
}

model AdminUser {
  id           String   @id
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("OPS")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
}

model Agent {
  id               String             @id
  email            String             @unique
  phone            String?
  fullName         String?
  passwordHash     String
  type             String             @default("PARTNER")
  status           String             @default("ACTIVE")
  createdBy        String?
  kpiRating        Float?
  totalRewards     Decimal            @default(0) @db.Decimal(24, 8)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  kpiEntries       AgentKpi[]
  transactions     AgentTransaction[]
  wallets          AgentWallet[]
  ledgerEntries    AgentLedgerEntry[]
  cashRequests     AgentCashRequest[]
  settlements      AgentSettlement[]
}

model AgentLedgerEntry {
  id        String   @id
  agentId   String
  type      String
  category  String
  amount    Decimal  @db.Decimal(24, 8)
  reference String?
  comment   String?
  uniqueKey String?  @unique
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model AgentWallet {
  id                String   @id
  agentId           String
  walletType        String
  network           String   @default("BASE")
  chain             String   @default("base")
  address           String   @unique
  crossmintWalletId String?
  walletLocator     String?
  balance           Decimal  @default(0) @db.Decimal(24, 8)
  status            String   @default("ACTIVE")
  lastSync          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agent             Agent    @relation(fields: [agentId], references: [id])
}

model AgentTransaction {
  id         String   @id
  agentId    String
  type       String
  amount     Decimal  @db.Decimal(24, 8)
  commission Decimal  @default(0) @db.Decimal(24, 8)
  netAmount  Decimal  @db.Decimal(24, 8)
  userRef    String?
  status     String   @default("COMPLETED")
  reference  String?  @unique
  metadata   Json?
  createdAt  DateTime @default(now())
  agent      Agent    @relation(fields: [agentId], references: [id])
}

model AgentKpi {
  id              String   @id
  agentId         String
  period          String
  periodStart     DateTime
  periodEnd       DateTime
  totalVolume     Decimal  @default(0) @db.Decimal(24, 8)
  totalCommission Decimal  @default(0) @db.Decimal(24, 8)
  totalTxCount    Int      @default(0)
  rewardPoints    Decimal  @default(0) @db.Decimal(24, 8)
  rating          Float?
  createdAt       DateTime @default(now())
  agent           Agent    @relation(fields: [agentId], references: [id])

  @@unique([agentId, period, periodStart])
}

model AgentCashRequest {
  id        String   @id
  agentId   String
  amount    Decimal  @db.Decimal(24, 8)
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id])
  settlement AgentSettlement?
}

model AgentSettlement {
  id              String   @id
  agentId         String
  cashRequestId   String?  @unique
  amount          Decimal  @db.Decimal(24, 8)
  bankName        String
  referenceNumber String
  proofImage      String?
  status          String   @default("PENDING")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  agent           Agent    @relation(fields: [agentId], references: [id])
  cashRequest     AgentCashRequest? @relation(fields: [cashRequestId], references: [id])
}

model AdminActionLog {
  id        String   @id
  adminId   String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model SystemAlert {
  id        String   @id
  severity  String   @default("MEDIUM")
  type      String?
  message   String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model FeeConfig {
  id                   String   @id
  transactionType      String   @unique
  label                String?
  description          String?
  systemFeeEnabled     Boolean  @default(true)
  systemFeeMode        String   @default("BOTH")
  systemFixedFee       Decimal  @default(0) @db.Decimal(24, 8)
  systemPercentFee     Decimal  @default(0) @db.Decimal(5, 2)
  processingFeeEnabled Boolean  @default(false)
  processingFeeMode    String   @default("FIXED")
  processingFixedFee   Decimal  @default(0) @db.Decimal(24, 8)
  processingPercentFee Decimal  @default(0) @db.Decimal(5, 2)
  superAdminOnly       Boolean  @default(false)
  enabled              Boolean  @default(true)
  updatedBy            String?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}
